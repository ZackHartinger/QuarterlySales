@{
    ViewData["Title"] = "Quarterly Sales";
}
@model QuarterlySalesViewModel


<h1 class="mb-3">@ViewBag.Title</h1>

<form asp-action="Index">
    <div class="row">
        <div class="col-2">
            <label asp-for="@Model.EmployeeId" class="form-label h5">Employee</label>
        </div>
        <div class="col-6">
            <select asp-route-id="@Model.Employee.EmployeeId" asp-for="@Model.EmployeeId" class="form-select form-control" asp-items="@(new SelectList(Model.Employees, "EmployeeId", "FullName"))">
                <option value="">Please select an employee</option>
            </select>
        </div>
        <div class="col-4">
            <button type="submit" class="btn btn-primary">Filter</a>
        </div>
    </div>

</form>

<table class="table">
    <thead>
        <th>Year</th>
        <th>Quarter</th>
        <th>Employee</th>
        <th>Amount</th>
    </thead>
    <tbody>
        @foreach(var sale in Model.Sales)
        {
            <tr>
                <td>@sale.Year</td>
                <td>@sale.Quarter</td>
                <td>@sale.Employee.FirstName  @sale.Employee.LastName</td>
                <td>@sale.Amount.ToString("c")</td>
            </tr>
        }
    </tbody>
</table>
