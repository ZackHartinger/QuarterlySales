@{
	ViewData["Title"] = "Add Employee";
}
@model QuarterlySalesViewModel
@section scripts {
	<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
	<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
	<script src="~/js/minimum-age.js"></script>
}

<style>
	.input-validation-error {
		border: 2px solid #dc3545;
		background-color: #faebd7;
	}
</style>

<h1>@ViewBag.Title</h1>
<form asp-action="AddToDB" method="post">
	<div class="row mb-2">
		<div class="col-md-2">
			<label asp-for="@Model.Employee.FirstName" class="form-label">First Name</label>
		</div>
		<div class="col-md-6">
			<input asp-for="@Model.Employee.FirstName" class="form-control" />
		</div>
		<div class="col-md-4">
			<span asp-validation-for="@Model.Employee.FirstName" class="text-danger"></span>
		</div>
	</div>
	<div class="row mb-2">
		<div class="col-md-2">
			<label asp-for="@Model.Employee.LastName" class="form-label">Last Name</label>
		</div>
		<div class="col-md-6">
			<input asp-for="@Model.Employee.LastName" class="form-control" />
		</div>
		<div class="col-md-4">
			<span asp-validation-for="@Model.Employee.LastName" class="text-danger"></span>
		</div>
	</div>
	<div class="row mb-2">
		<div class="col-md-2">
			<label asp-for="@Model.Employee.DOB" class="form-label">Birth Date</label>
		</div>
		<div class="col-md-6">
			<input type="date" asp-for="@Model.Employee.DOB" class="form-control" />
		</div>
		<div class="col-md-4">
			<span asp-validation-for="@Model.Employee.DOB" class="text-danger"></span>
		</div>
	</div>
	<div class="row mb-3">
		<div class="col-md-2">
			<label asp-for="@Model.Employee.HireDate" class="form-label">Hire Date</label>
		</div>
		<div class="col-md-6">
			<input type="date" asp-for="@Model.Employee.HireDate" class="form-control" />
		</div>
		<div class="col-md-4">
			<span asp-validation-for= "@Model.Employee.HireDate" class="text-danger"></span>
		</div>
	</div>
	<div class="row mb-3">
		<div class="col-md-2">
			<label asp-for="@Model.Employee.ManagerId" class="form-label">Manager</label>
		</div>
		<div class="col-md-6">
			<select asp-for="@Model.Employee.ManagerId" class="form-select form-control" 
				asp-items="@(new SelectList(Model.Employees, "EmployeeId", "FullName"))">
				<option value="">Please select a manager</option>
			</select>
		</div>
		<div class="col-md-4">
			<span asp-validation-for="@Model.Employee.ManagerId" class="text-danger"></span>
		</div>
	</div>

	<input type="hidden" asp-for="Employee.EmployeeId" />

	<button type="submit" class="btn btn-primary">Add</button>
	<a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary">Cancel</a>
</form>
