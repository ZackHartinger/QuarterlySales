@{
    ViewData["Title"] = "Add Sales";
}
@model QuarterlySalesViewModel
@section scripts {
	<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
	<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
	<script src="~/js/minimum-age.js"></script>
}

<style>
	.input-validation-error {
		border: 2px solid #dc3545;
		background-color: #faebd7;
	}
</style>

<h1>@ViewBag.Title</h1>

<form asp-action="AddToDB" method="post">
	<div class="row mb-2">
		<div class="col-md-2">
			<label asp-for="@Model.Sale.Quarter" class="form-label">Quarter</label>	
		</div>
		<div class="col-md-6">
			<input type="text" asp-for="@Model.Sale.Quarter" class="form-control" />
		</div>
		<div class="col-md-4">
			<span asp-validation-for="@Model.Sale.Quarter" class="text-danger"></span>
		</div>
	</div>
	<div class="row mb-2">
		<div class="col-md-2">
			<label asp-for="@Model.Sale.Year" class="form-label">Year</label>
		</div>
		<div class="col-md-6">
			<input type="text" asp-for="@Model.Sale.Year" class="form-control" />
		</div>
		<div class="col-md-4">
			<span asp-validation-for="@Model.Sale.Year" class="text-danger"></span>
		</div>
	</div>
	<div class="row mb-2">
		<div class="col-md-2">
			<label asp-for="@Model.Sale.Amount" class="form-label">Amount</label>
		</div>
		<div class="col-md-6">
			<input type="text" asp-for="@Model.Sale.Amount" class="form-control" />
		</div>
		<div class="col-md-4">
			<span asp-validation-for="@Model.Sale.Amount" class="text-danger"></span>
		</div>
	</div>
	<div class="row mb-3">
		<div class="col-md-2">
			<label asp-for="@Model.Sale.EmployeeId" class="form-label">Employee</label>
		</div>
		<div class="col-md-6">
			<select asp-for="@Model.Sale.EmployeeId" class="form-select form-control" asp-items="@(new SelectList(Model.Employees, "EmployeeId", "FullName"))">
				<option value="">Please select an employee</option>
			</select>
		</div>
		<div class="col-md-4">
			<span asp-validation-for="@Model.Sale.EmployeeId" class="text-danger"></span>
		</div>
	</div>

	<input type="hidden" asp-for="Sale.SaleId" />

	<button type="submit" class="btn btn-primary">Add</button>
	<a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary">Cancel</a>
</form>
